@import "../../styles/theme.wxss";

.list-wrap {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-card,
.empty-card {
  padding: 20rpx;
  background: linear-gradient(180deg, #ffffff, #fffdfd);
  animation: fade-up 0.4s ease both;
}

.history-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.history-type,
.empty-title {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #313937;
}

.history-time,
.empty-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a8480;
}

.history-sub {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.58;
  color: #66726f;
}
