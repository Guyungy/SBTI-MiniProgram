@import "../../styles/theme.wxss";

.hero-card {
  padding: 28rpx 24rpx 24rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #fffdfd 0%, #fbfffd 52%, #f7faf8 100%);
  animation: fade-up 0.42s ease both;
}

.deco {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
  opacity: 0.88;
}

.deco-peach {
  width: 170rpx;
  height: 170rpx;
  top: -44rpx;
  right: -34rpx;
  background: radial-gradient(circle, rgba(255, 214, 225, 0.94) 0%, rgba(255, 214, 225, 0.16) 70%, rgba(255, 214, 225, 0) 100%);
  animation: floaty-soft 5s ease-in-out infinite;
}

.deco-mint {
  width: 138rpx;
  height: 138rpx;
  right: 28rpx;
  top: 176rpx;
  background: radial-gradient(circle, rgba(196, 236, 217, 0.9) 0%, rgba(196, 236, 217, 0.16) 72%, rgba(196, 236, 217, 0) 100%);
  animation: floaty-soft 5.8s ease-in-out infinite;
}

.eyebrow {
  position: relative;
  z-index: 1;
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f6efff;
  color: #8665a0;
  font-size: 22rpx;
  font-weight: 600;
}

.title-wrap,
.hero-desc,
.stat-grid,
.feature-row,
.latest-card,
.hero-btn,
.text-btn {
  position: relative;
  z-index: 1;
}

.title-wrap {
  margin-top: 18rpx;
}

.title-line {
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  color: #2f3835;
}

.accent {
  color: #e88ea8;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #66726f;
}

.stat-grid {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.stat-card {
  flex: 1;
  padding: 16rpx 12rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fcfefe);
  border: 1rpx solid #efe8f2;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #303937;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7b8784;
}

.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.feature-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fcf4fb;
  border: 1rpx solid #f2e3ec;
  color: #8a6877;
  font-size: 22rpx;
}

.latest-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff, #fbfcfe);
  border: 1rpx solid #eee7ef;
}

.latest-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.latest-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #313a37;
}

.latest-time {
  font-size: 20rpx;
  color: #87918d;
}

.latest-type {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #313937;
}

.latest-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #66726f;
}

.btn {
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.hero-btn {
  margin-top: 22rpx;
  animation: pulse-soft 2.8s ease-in-out infinite;
}

.small-btn {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
}

.text-btn {
  margin-top: 14rpx;
  text-align: center;
  color: #846676;
  font-size: 26rpx;
}
